{
  "name": "@nookdb/electron",
  "version": "1.0.0",
  "description": "Electron multi-process bindings for nookdb — main/preload/renderer IPC bridge.",
  "homepage": "https://github.com/nookwright/nookdb/tree/main/packages/electron#readme",
  "keywords": [
    "nookdb",
    "electron",
    "database",
    "ipc",
    "multi-process"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nookwright/nookdb.git",
    "directory": "packages/electron"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./main": {
      "types": "./dist/main/index.d.ts",
      "import": "./dist/main/index.js"
    },
    "./preload": {
      "types": "./dist/preload/index.d.ts",
      "import": "./dist/preload/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0"
  },
  "engines": {
    "node": ">= 20"
  },
  "peerDependencies": {
    "nookdb": "^1.0.0",
    "electron": ">=28"
  },
  "devDependencies": {
    "nookdb": "workspace:*",
    "electron": "^30.0.0",
    "@playwright/test": "^1.45.0",
    "playwright": "^1.45.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
