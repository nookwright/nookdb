    "lint": "eslint src --max-warnings=0"
  },
  "peerDependencies": {
    "nookdb": "workspace:*",
    "react": ">=18"
  },
  "devDependencies": {
    "nookdb": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
