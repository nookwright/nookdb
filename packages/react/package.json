{
  "name": "@nookdb/react",
  "version": "1.0.0",
  "description": "React hooks for nookdb — reactive live queries for React apps.",
  "homepage": "https://github.com/nookwright/nookdb/tree/main/packages/react#readme",
  "keywords": [
    "nookdb",
    "react",
    "database",
    "reactive",
    "hook"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nookwright/nookdb.git",
    "directory": "packages/react"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0"
  },
  "engines": {
    "node": ">= 20"
  },
  "peerDependencies": {
    "nookdb": "^1.0.0",
    "react": ">=18"
  },
  "devDependencies": {
    "nookdb": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
