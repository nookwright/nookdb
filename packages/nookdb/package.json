{
  "name": "nookdb",
  "version": "0.0.1",
  "description": "Schema-first, reactive, local-first database for Electron desktop apps.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@nookdb/binding": "workspace:*",
    "@vitest/coverage-v8": "^1.6.1"
  },
  "engines": {
    "node": ">= 20"
  },
  "keywords": [
    "database",
    "electron",
    "local-first",
    "reactive",
    "typescript",
    "rust"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nookwright/nookdb.git"
  },
  "homepage": "https://github.com/nookwright/nookdb#readme"
}
