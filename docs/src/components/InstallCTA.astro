---
import { copy } from '../lib/copy';
const cta = copy.installCta;
---

<section class="install-cta section-reveal reveal-stagger" aria-labelledby="cta-heading">
  <div class="install-cta__inner">
    <h2 class="install-cta__heading reveal-item" id="cta-heading" style="--rev-i: 0">
      {cta.heading.replace(/\.$/, '')}<span class="install-cta__period" aria-hidden="true">.</span>
    </h2>

    <!-- Complete, runnable example — the "0 to running" moment -->
    <figure class="install-cta__example reveal-item" style="--rev-i: 1">
      <div class="install-cta__example-chrome">
        <span class="install-cta__dot" aria-hidden="true"></span>
        <span class="install-cta__dot" aria-hidden="true"></span>
        <span class="install-cta__dot" aria-hidden="true"></span>
        <span class="install-cta__filename">app.ts</span>
      </div>
      <pre class="install-cta__example-code"><code>{ cta.example }</code></pre>
      <figcaption class="install-cta__example-caption">{ cta.exampleCaption }</figcaption>
    </figure>

    <div class="install-cta__row reveal-item" style="--rev-i: 2">
      <code class="install-cta__code">
        { copy.hero.install }
        <span class="install-cta__sheen" aria-hidden="true"></span>
      </code>
      <button
        class="install-cta__copy"
        type="button"
        data-copy-install
        aria-label="Copy install command to clipboard"
      >
        <span class="sr-only" data-copy-text>{ copy.hero.install }</span>
        <span data-copy-hint>Click to copy</span>
      </button>
    </div>

    <p class="install-cta__starter reveal-item" style="--rev-i: 3">
      <span class="install-cta__starter-label">{ cta.starterLabel }</span>
      <a class="install-cta__starter-link" href={ cta.starterHref } target="_blank" rel="noopener noreferrer">
        { cta.starterRepoName } →
      </a>
    </p>

    <div class="install-cta__secondary reveal-item" style="--rev-i: 4">
      <a href={ cta.githubHref } target="_blank" rel="noopener noreferrer">
        <span class="install-cta__star" aria-hidden="true">★</span>{ cta.githubLabel }
      </a>
      <span class="install-cta__dot-sep" aria-hidden="true">·</span>
      <a href={ copy.architecture.linkHref }>
        { copy.hero.secondaryCta }
      </a>
    </div>
  </div>
</section>

<style>
  .install-cta {
    padding: 120px 24px;
    text-align: center;
  }

  .install-cta__inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .install-cta__heading {
    font-family: var(--font-sans);
    font-size: 28px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 36px;
    letter-spacing: -0.01em;
  }
  /* trailing period blinks in mint after the heading lands —
     a tiny "ready" cursor that punctuates the call-to-action */
  .install-cta__period {
    display: inline-block;
    color: var(--mint);
    transform-origin: bottom center;
    animation: cta-period-pop 720ms var(--ease-reveal) 540ms both;
  }
  @keyframes cta-period-pop {
    0%   { opacity: 0; transform: scale(0.4) translateY(2px); }
    60%  { opacity: 1; transform: scale(1.3) translateY(0); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* ── Complete runnable example ───────────────────────────────────── */
  .install-cta__example {
    margin: 0 0 40px;
    text-align: left;
    background: var(--bg-code);
    border: 1px solid var(--border-default);
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--shadow-elevated);
  }

  .install-cta__example-chrome {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 11px 16px;
    border-bottom: 1px solid var(--border-subtle);
    background: var(--bg-popover);
  }

  .install-cta__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--text-muted);
    opacity: 0.4;
  }

  .install-cta__filename {
    margin-left: 6px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
  }

  .install-cta__example-code {
    margin: 0;
    padding: 20px 22px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.75;
    color: var(--text-primary);
    white-space: pre;
    overflow-x: auto;
    background: transparent;
  }

  .install-cta__example-caption {
    margin: 0;
    padding: 12px 16px;
    border-top: 1px solid var(--border-subtle);
    font-family: var(--font-mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    text-align: center;
    background: var(--bg-popover);
  }

  .install-cta__row {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  /* ── Install command box — gets a mint sheen sweep on reveal ─────── */
  .install-cta__code {
    position: relative;
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--text-primary);
    background: var(--bg-code);
    padding: 16px 24px;
    border: 1px solid var(--border);
    border-radius: var(--radius-base);
    white-space: nowrap;
    overflow: hidden;
    isolation: isolate;
  }
  /* sheen — diagonal mint gradient swipes left→right one time on reveal */
  .install-cta__sheen {
    position: absolute;
    top: 0;
    bottom: 0;
    left: -40%;
    width: 35%;
    background: linear-gradient(
      105deg,
      transparent 0%,
      rgba(168, 201, 127, 0.0) 35%,
      rgba(168, 201, 127, 0.22) 50%,
      rgba(168, 201, 127, 0.0) 65%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 1;
    transform: translateX(0);
  }
  .reveal-stagger.is-visible .install-cta__row .install-cta__sheen {
    animation: cta-sheen 1400ms var(--ease-reveal) 540ms both;
  }
  @keyframes cta-sheen {
    0%   { transform: translateX(0); opacity: 0; }
    20%  { opacity: 1; }
    80%  { opacity: 1; }
    100% { transform: translateX(380%); opacity: 0; }
  }

  .install-cta__copy {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--accent);
    padding: 10px 16px;
    border: 1px solid var(--accent);
    border-radius: var(--radius-base);
    background: transparent;
    cursor: pointer;
    transition: color var(--motion-dur) var(--ease-out),
                border-color var(--motion-dur) var(--ease-out);
  }

  .install-cta__copy:hover {
    color: var(--accent-deep);
    border-color: var(--accent-deep);
  }

  .install-cta__copy:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .install-cta__copy [data-copy-hint] {
    font-size: 12px;
    color: var(--text-muted);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* "or clone a working repo" — tertiary cue under the install line */
  .install-cta__starter {
    margin: 20px 0 0;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    text-align: center;
  }
  .install-cta__starter-label {
    margin-right: 8px;
  }
  .install-cta__starter-link {
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--border-default);
    text-underline-offset: 3px;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .install-cta__starter-link:hover {
    color: var(--accent);
  }

  .install-cta__secondary {
    margin-top: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* star icon — gentle one-shot wobble on reveal, hover scales it up */
  .install-cta__star {
    display: inline-block;
    color: var(--mint);
    margin-right: 7px;
    transform-origin: center;
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .install-cta__secondary a:hover .install-cta__star {
    transform: scale(1.18) rotate(8deg);
  }
  .reveal-stagger.is-visible .install-cta__secondary .install-cta__star {
    animation: cta-star-pulse 900ms var(--ease-reveal) 720ms both;
  }
  @keyframes cta-star-pulse {
    0%   { transform: scale(0.6) rotate(-20deg); opacity: 0; }
    50%  { transform: scale(1.25) rotate(6deg);  opacity: 1; }
    100% { transform: scale(1)    rotate(0deg);  opacity: 1; }
  }

  .install-cta__dot-sep {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .install-cta__secondary a {
    font-size: 14px;
    color: var(--accent);
    text-decoration: none;
    transition: text-decoration var(--motion-dur) var(--ease-out);
  }

  .install-cta__secondary a:hover {
    text-decoration: underline;
  }

  .install-cta__secondary a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ── Reduced motion ──────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .install-cta__period,
    .install-cta__sheen,
    .install-cta__star {
      animation: none !important;
      opacity: 1;
      transform: none;
    }
    .install-cta__sheen { display: none; }
  }

  /* Mobile stack: below 480px */
  @media (max-width: 480px) {
    .install-cta__row {
      flex-direction: column;
    }

    .install-cta__code {
      width: 100%;
      box-sizing: border-box;
    }
  }
</style>

<script>
  import '../scripts/copy-install.ts';
  import '../scripts/reveal.ts';
</script>
