---
import { copy } from '../lib/copy';
import HeroRepl from './HeroRepl.astro';
---

<section class="hero" aria-labelledby="hero-heading">
  <!-- Technical dot-grid backdrop — flat, matte, structural; fades outward -->
  <div class="hero__grid" aria-hidden="true"></div>

  <!-- Aurora mesh backdrop — restrained pearl wash (toned for a flatter matte feel) -->
  <div class="hero__aurora" aria-hidden="true">
    <div class="hero__aurora-blob hero__aurora-blob--1"></div>
    <div class="hero__aurora-blob hero__aurora-blob--2"></div>
    <div class="hero__aurora-blob hero__aurora-blob--3"></div>
    <div class="hero__aurora-grain"></div>
  </div>

  <div class="hero__inner">

    <!-- LEFT: headline, subhead, install row, secondary link -->
    <div class="hero__left">

      <h1 id="hero-heading" class="hero__headline hero__rise" style="--rise-delay: 80ms">
        {copy.hero.headline}
      </h1>

      <p class="hero__subhead hero__rise" style="--rise-delay: 200ms">
        {copy.hero.subhead}
      </p>

      <!-- Install line + copy button -->
      <div class="hero__install-row hero__rise" style="--rise-delay: 320ms">
        <code class="hero__install-code">
          <span class="hero__install-prompt" aria-hidden="true">$</span>
          <span class="hero__install-cmd">{copy.hero.install}</span>
        </code>
        <button
          class="hero__copy-btn"
          type="button"
          data-copy-install
          aria-label="Copy install command to clipboard"
        >
          <span class="sr-only" data-copy-text>{copy.hero.install}</span>
          <span data-copy-hint>copy</span>
        </button>
      </div>

      <!-- Secondary links: quick-start first (eager devs), architecture second (skeptics) -->
      <div class="hero__secondary hero__rise" style="--rise-delay: 420ms">
        <a class="hero__secondary-link hero__secondary-link--primary" href={copy.hero.quickStartHref}>
          {copy.hero.quickStartCta}
        </a>
        <a class="hero__secondary-link" href={copy.architecture.linkHref}>
          {copy.hero.secondaryCta}
        </a>
      </div>

    </div><!-- /.hero__left -->

    <!-- RIGHT: interactive NookDB shell (REPL) with lamp glow -->
    <div class="hero__right hero__rise" style="--rise-delay: 320ms">
      <div class="hero__centerpiece lamp-glow">
        <HeroRepl />
      </div>
    </div>

  </div><!-- /.hero__inner -->
</section>

<!-- Pre-release notice -->
<p class="hero__pre-release">
  <em>{copy.hero.preReleaseNote}</em>
</p>

<style>
  /* ── Section ─────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    padding-top: 80px;
    padding-bottom: 64px;
    min-height: calc(88vh - 80px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  /* ── Aurora mesh backdrop ────────────────────────────────────────
   * Three large blurred radial blobs drift slowly behind the hero,
   * forming a soft living gradient. Pearl-dominant; one restrained
   * mint blob for cool depth. A grain layer sits on top to break up
   * the blur into a tactile, premium texture. */
  .hero__aurora {
    position: absolute;
    inset: -10% -5% 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    /* Fade the whole mesh out toward the bottom so the section below
       transitions cleanly into flat black. */
    -webkit-mask-image: linear-gradient(to bottom, #000 55%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 55%, transparent 100%);
  }

  /* Technical dot-grid — monochrome, very low contrast, masked to fade out.
     Adds structure that ties the hero to the diagrammatic language used in
     the sections below, while staying flat and matte. */
  .hero__grid {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(circle, rgba(242, 239, 234, 0.05) 1px, transparent 1px);
    background-size: 34px 34px;
    -webkit-mask-image: radial-gradient(ellipse 78% 62% at 50% 38%, #000 0%, transparent 76%);
    mask-image: radial-gradient(ellipse 78% 62% at 50% 38%, #000 0%, transparent 76%);
  }

  .hero__aurora-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(96px);
    will-change: transform;
    opacity: 0.3;
  }

  /* Blob 1 — large pearl wash, upper-left, behind the headline */
  .hero__aurora-blob--1 {
    width: 680px;
    height: 680px;
    top: -22%;
    left: -8%;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(242, 239, 234, 0.16) 0%,
      rgba(242, 239, 234, 0) 68%
    );
    animation: hero-aurora-1 26s ease-in-out infinite;
  }

  /* Blob 2 — warm cream, drifting behind the centerpiece card */
  .hero__aurora-blob--2 {
    width: 560px;
    height: 560px;
    top: -6%;
    right: -4%;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(242, 239, 234, 0.12) 0%,
      rgba(242, 239, 234, 0) 66%
    );
    animation: hero-aurora-2 32s ease-in-out infinite;
  }

  /* Blob 3 — restrained mint, low + centered, the cool counterweight */
  .hero__aurora-blob--3 {
    width: 520px;
    height: 520px;
    bottom: -18%;
    left: 34%;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(168, 201, 127, 0.10) 0%,
      rgba(168, 201, 127, 0) 64%
    );
    animation: hero-aurora-3 38s ease-in-out infinite;
  }

  /* Tactile grain over the smooth blur */
  .hero__aurora-grain {
    position: absolute;
    inset: 0;
    background-image: var(--bg-noise);
    background-repeat: repeat;
    opacity: 0.9;
    mix-blend-mode: overlay;
  }

  @keyframes hero-aurora-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(60px, 40px) scale(1.12); }
  }
  @keyframes hero-aurora-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(-50px, 50px) scale(1.1); }
  }
  @keyframes hero-aurora-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(40px, -40px) scale(1.15); }
  }

  /* ── Staggered entrance — content rises + fades on load ──────────── */
  .hero__rise {
    opacity: 0;
    transform: translateY(18px);
    animation: hero-rise 700ms var(--ease-out) both;
    animation-delay: var(--rise-delay, 0ms);
  }

  @keyframes hero-rise {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Inner grid ─────────────────────────────────────────────────── */
  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: var(--max-content-width);
    margin: 0 auto;
    padding: 0 var(--s-6);
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 520px;
    gap: 64px;
    align-items: center;
  }

  /* ── LEFT column ────────────────────────────────────────────────── */
  .hero__headline {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 52px;
    line-height: 1.1;
    color: var(--text-primary);
    max-width: 600px;
    margin: 0 0 24px;
    letter-spacing: -0.02em;
  }

  .hero__subhead {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 22px;
    line-height: var(--line-height-body);
    color: var(--text-muted);
    max-width: 540px;
    margin: 0 0 32px;
  }

  /* ── Install row ────────────────────────────────────────────────── */
  .hero__install-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .hero__install-code {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--text-primary);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0)) ,
      var(--bg-code);
    padding: 13px 20px;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-base);
    white-space: nowrap;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 8px 24px rgba(0, 0, 0, 0.35);
  }

  .hero__install-prompt {
    color: var(--mint);
    font-weight: 600;
    opacity: 0.85;
    user-select: none;
  }

  .hero__install-cmd {
    color: var(--text-primary);
  }

  .hero__copy-btn {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--accent);
    padding: 10px 16px;
    border: 1px solid var(--accent);
    border-radius: var(--radius-base);
    background: transparent;
    cursor: pointer;
    transition: color var(--motion-dur) var(--ease-out),
                border-color var(--motion-dur) var(--ease-out);
  }

  .hero__copy-btn:hover {
    color: var(--accent-hover);
    border-color: var(--accent-hover);
  }

  .hero__copy-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .hero__copy-btn [data-copy-hint] {
    font-family: var(--font-mono);
    font-size: 12px;
  }

  /* ── Secondary links ────────────────────────────────────────────── */
  .hero__secondary {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-top: 16px;
    flex-wrap: wrap;
  }

  .hero__secondary-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--motion-dur) var(--ease-out),
                text-decoration var(--motion-dur) var(--ease-out);
  }

  /* the primary intent — quick start — reads brighter */
  .hero__secondary-link--primary {
    color: var(--accent);
    font-weight: 500;
  }

  .hero__secondary-link:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }

  .hero__secondary-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ── RIGHT column ───────────────────────────────────────────────── */
  .hero__right {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__centerpiece {
    width: 100%;
  }

  /* Stronger, warmer lamp glow behind the centerpiece (overrides the
     global .lamp-glow utility just for the hero). */
  .hero__centerpiece.lamp-glow::before {
    width: 620px;
    height: 620px;
    opacity: 0.16;
    filter: blur(40px);
    background: radial-gradient(
      circle,
      rgba(242, 239, 234, 0.9) 0%,
      rgba(232, 215, 188, 0.35) 35%,
      transparent 62%
    );
  }

  /* ── Pre-release notice ─────────────────────────────────────────── */
  .hero__pre-release {
    font-size: 13px;
    color: var(--text-muted);
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
    padding: 24px var(--s-6);
    border-top: 1px solid var(--border);
  }

  .hero__pre-release em {
    font-style: italic;
  }

  /* ── Accessibility helper ───────────────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* ── Tablet: 880–1079px (two equal columns) ─────────────────────── */
  @media (max-width: 1079px) and (min-width: 880px) {
    .hero__inner {
      grid-template-columns: 1fr 1fr;
    }
    .hero__headline {
      font-size: 36px;
    }
    .hero__subhead {
      font-size: 18px;
    }
  }

  /* ── Reduced motion ─────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero__aurora-blob {
      animation: none;
    }
    .hero__rise {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  /* ── Mobile: < 880px (single column, centerpiece below) ─────────── */
  @media (max-width: 879px) {
    .hero {
      padding-top: 48px;
      padding-bottom: 40px;
      min-height: auto;
    }
    .hero__bg-shape--1, .hero__bg-shape--3 {
      display: none;
    }
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero__headline {
      font-size: 28px;
      max-width: 100%;
    }
    .hero__subhead {
      font-size: 18px;
      max-width: 100%;
    }
    .hero__centerpiece {
      max-width: 480px;
      margin: 0 auto;
    }
    .hero__install-code {
      font-size: 14px;
      padding: 12px 16px;
      white-space: normal;
      word-break: break-all;
    }
  }
</style>

<script>
  import '../scripts/copy-install.ts';
</script>
