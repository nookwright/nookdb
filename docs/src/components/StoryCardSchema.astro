---
import { copy } from '../lib/copy';
const c = copy.story.schema;

// Fields rendered in the single source-of-truth panel (left). The same field
// set surfaces — by inference, never re-typed — across the three usage panes
// on the right. `Todo` is the one token the eye tracks everywhere.
const fields = [
  { name: 'id', call: 's.id()', type: 'string' },
  { name: 'title', call: 's.string()', type: 'string' },
  { name: 'done', call: 's.boolean()', type: 'boolean' },
  { name: 'createdAt', call: 's.date()', type: 'Date' },
];
---

<section class="story-card-slot">
  <div class="story-card story-card--schema">
    <div class="story-card__inner">
      <h2 class="story-card__title">{c.title}</h2>
      <p class="story-card__body" set:html={c.body.replace(/`(.+?)`/g, '<code>$1</code>')}></p>

      <div class="scs" aria-label="One schema definition; its inferred type appears across reads, writes, and updates">
        <!-- ── SOURCE: the single place you type a schema ──────────────── -->
        <div class="scs__source">
          <div class="scs__tag">
            <span class="scs__tag-dot" aria-hidden="true"></span>
            type once
          </div>

          <pre class="scs__code"><span class="scs__ln"><span class="scs__kw">const</span> schema = {'{'}</span>
<span class="scs__ln">  todos: <span class="scs__fn">s.collection</span>({'{'}</span>
{fields.map((f) => (
  <span class="scs__ln">    <span class="scs__field">{f.name}</span><span class="scs__dim">:</span> <span class="scs__call">{f.call}</span><span class="scs__dim">,</span></span>
))}
<span class="scs__ln">  {'}'}),</span>
<span class="scs__ln">{'}'}</span>
<span class="scs__ln scs__ln--spaced"><span class="scs__kw">type</span> <span class="scs__t">Todo</span> = <span class="scs__dim">typeof</span> schema.todos.<span class="scs__prop">$type</span></span>
<span class="scs__ln scs__comment">{'//   '}↑ inferred once — never written by hand</span></pre>
        </div>

        <!-- ── RAIL: type radiates from the source to every surface ────── -->
        <div class="scs__rail" aria-hidden="true">
          <span class="scs__spine"></span>
          <span class="scs__hub"></span>
          <span class="scs__pulse scs__pulse--up"></span>
          <span class="scs__pulse scs__pulse--down"></span>
        </div>

        <!-- ── SURFACES: where Todo shows up, automatically ────────────── -->
        <div class="scs__surfaces">
          <!-- READ -->
          <article class="scs__surface" style="--i: 0">
            <header class="scs__surface-head">
              <span class="scs__surface-kind">read</span>
              <span class="scs__surface-note">autocomplete · inferred return</span>
            </header>
            <pre class="scs__snippet"><span class="scs__kw">const</span> open = <span class="scs__kw">await</span> db.todos.<span class="scs__fn">find</span>()
<span class="scs__comment">//    ↑ open: <span class="scs__t">Todo</span>[]</span>
open[<span class="scs__num">0</span>].<span class="scs__caret">▏</span><span class="scs__pop"><span class="scs__pop-row"><span class="scs__pop-name">title</span><span class="scs__pop-type">string</span></span><span class="scs__pop-row"><span class="scs__pop-name">done</span><span class="scs__pop-type">boolean</span></span></span></pre>
          </article>

          <!-- WRITE -->
          <article class="scs__surface" style="--i: 1">
            <header class="scs__surface-head">
              <span class="scs__surface-kind">write</span>
              <span class="scs__surface-note">typo caught at compile time</span>
            </header>
            <pre class="scs__snippet">db.todos.<span class="scs__fn">insert</span>({'{'}
  <span class="scs__err">titel</span>: <span class="scs__str">"Ship it"</span>,
{'}'})
<span class="scs__diag"><span class="scs__diag-x">✗</span> 'titel' does not exist in <span class="scs__t">Todo</span></span></pre>
          </article>

          <!-- UPDATE -->
          <article class="scs__surface" style="--i: 2">
            <header class="scs__surface-head">
              <span class="scs__surface-kind">update</span>
              <span class="scs__surface-note">patch shape checked</span>
            </header>
            <pre class="scs__snippet">db.todos.<span class="scs__fn">update</span>(
  {'{'} id {'}'},
  {'{'} done: <span class="scs__err">"yes"</span> {'}'},
)
<span class="scs__diag"><span class="scs__diag-x">✗</span> done: <span class="scs__t">boolean</span> — string not assignable</span></pre>
          </article>
        </div>
      </div>

      <div class="scs__footer">
        <span class="scs__footer-text">
          one definition · zero codegen · no <code>as</code> casts · no drift
        </span>
      </div>
    </div>
  </div>
</section>

<link rel="stylesheet" href="/src/styles/story-cards.css" />
<script>
  import '../scripts/story-cards.ts';
</script>

<style>
  /* ── Stage grid ─────────────────────────────────────────────────────
     Source spans all rows on the left; the rail is a thin radiating spine;
     three usage surfaces stack on the right, each in its own row so the
     rail's branch stubs align to their centers automatically. */
  .scs {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 60px minmax(0, 1.04fr);
    grid-template-rows: repeat(3, auto);
    column-gap: 0;
    row-gap: 18px;
    max-width: 960px;
    width: 100%;
    margin: 36px auto 0;
    align-items: stretch;
  }

  /* ── SOURCE panel ───────────────────────────────────────────────── */
  .scs__source {
    position: relative;
    grid-column: 1;
    grid-row: 1 / span 3;
    align-self: center;
    background: var(--bg-code);
    border: 1px solid var(--border-default);
    border-radius: var(--r-lg);
    padding: 18px 22px 20px;
    box-shadow: var(--shadow-elevated);
    overflow: hidden;
  }

  /* lamp glow behind the origin — this is the light everything flows from */
  .scs__source::before {
    content: '';
    position: absolute;
    top: -30%;
    left: -10%;
    width: 70%;
    height: 80%;
    background: radial-gradient(circle, var(--lamp-glow-color) 0%, transparent 62%);
    opacity: 0.07;
    filter: blur(26px);
    pointer-events: none;
  }

  .scs__tag {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 9.5px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    margin-bottom: 14px;
  }

  .scs__tag-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 7px var(--accent);
    opacity: 0.85;
  }

  /* ── Code typography (shared by source + snippets) ──────────────── */
  .scs__code,
  .scs__snippet {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.75;
    color: var(--text-primary);
    margin: 0;
    white-space: pre;
    background: transparent;
    border: 0;
    padding: 0;
    position: relative;
  }

  .scs__ln { display: block; }
  .scs__ln--spaced { margin-top: 14px; }

  .scs__kw    { color: var(--text-secondary); }
  .scs__fn    { color: var(--text-primary); font-weight: 600; }
  .scs__field { color: var(--text-primary); }
  .scs__call  { color: var(--text-secondary); }
  .scs__prop  { color: var(--mint); }
  .scs__dim   { color: var(--text-muted); }
  .scs__num   { color: var(--text-secondary); }
  .scs__str   { color: var(--mint); }
  .scs__comment { color: var(--text-muted); opacity: 0.7; }

  /* The repeated token — the whole point. Same pill everywhere `Todo` lands. */
  .scs__t {
    color: var(--bg);
    background: var(--accent);
    padding: 0 6px;
    border-radius: 4px;
    font-weight: 600;
  }

  /* ── RAIL: vertical spine + radiating pulses ────────────────────── */
  .scs__rail {
    position: relative;
    grid-column: 2;
    grid-row: 1 / span 3;
  }

  .scs__spine {
    position: absolute;
    left: 50%;
    top: 6%;
    bottom: 6%;
    width: 1px;
    transform: translateX(-50%);
    background: linear-gradient(
      to bottom,
      transparent,
      var(--border-default) 12%,
      var(--border-default) 88%,
      transparent
    );
  }

  /* hub: where the source plugs into the rail (vertical center) */
  .scs__hub {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
  }

  /* stub from source right edge into the hub */
  .scs__source::after {
    content: '';
    position: absolute;
    right: -30px;
    top: 50%;
    width: 30px;
    height: 1px;
    background: var(--border-default);
    pointer-events: none;
  }

  /* two pulses radiate outward from the hub along the spine */
  .scs__pulse {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    opacity: 0;
  }

  /* ── SURFACES ───────────────────────────────────────────────────── */
  .scs__surfaces {
    grid-column: 3;
    grid-row: 1 / span 3;
    display: grid;
    grid-template-rows: repeat(3, 1fr);
    row-gap: 18px;
  }

  .scs__surface {
    position: relative;
    background: var(--bg-code);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: 12px 16px 14px;
    opacity: 0;
    transform: translateX(10px);
    transition:
      opacity calc(var(--motion-dur) * 1.4) var(--ease-out),
      transform calc(var(--motion-dur) * 1.4) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  /* branch stub reaching from each surface's left edge toward the rail */
  .scs__surface::before {
    content: '';
    position: absolute;
    left: -30px;
    top: 50%;
    width: 30px;
    height: 1px;
    background: var(--border-default);
    opacity: 0.6;
    pointer-events: none;
  }

  .scs__surface-head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 8px;
  }

  .scs__surface-kind {
    font-family: var(--font-mono);
    font-size: 9.5px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-primary);
    font-weight: 600;
  }

  .scs__surface-note {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .scs__snippet { font-size: 12px; line-height: 1.7; }

  /* error token — red squiggle underline */
  .scs__err {
    color: var(--error);
    text-decoration: underline wavy var(--error);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  /* diagnostic line under the snippet */
  .scs__diag {
    display: block;
    margin-top: 6px;
    font-size: 10.5px;
    color: var(--text-muted);
    white-space: normal;
  }
  .scs__diag-x { color: var(--error); margin-right: 5px; font-weight: 600; }

  /* blinking caret + autocomplete popup (read surface) */
  .scs__caret {
    color: var(--accent);
    animation: scs-blink 1.1s steps(1) infinite;
  }

  .scs__pop {
    display: inline-block;
    vertical-align: top;
    margin-left: 2px;
    background: var(--bg-popover);
    border: 1px solid var(--border-default);
    border-radius: 6px;
    padding: 4px 0;
    box-shadow: var(--shadow-subtle);
    overflow: hidden;
  }
  .scs__pop-row {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    padding: 2px 12px;
    font-size: 11px;
  }
  .scs__pop-row:first-child { background: var(--accent-subtle); }
  .scs__pop-name { color: var(--text-primary); }
  .scs__pop-type { color: var(--mint); }

  /* ── FOOTER caption ─────────────────────────────────────────────── */
  .scs__footer {
    text-align: center;
    margin-top: 22px;
  }
  .scs__footer-text {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .scs__footer-text code {
    background: var(--accent-subtle);
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 9.5px;
    color: var(--text-secondary);
  }

  /* ── REVEAL + MOTION (gated on scrollytelling .is-active) ────────── */
  .story-card.is-active .scs__surface {
    opacity: 1;
    transform: translateX(0);
    /* staggered: each surface lights as the pulse reaches it */
    transition-delay: calc(0.25s + var(--i) * 0.18s);
  }

  .story-card.is-active .scs__pulse--up {
    animation: scs-radiate-up 2.6s var(--ease-out) infinite;
    animation-delay: 0.3s;
  }
  .story-card.is-active .scs__pulse--down {
    animation: scs-radiate-down 2.6s var(--ease-out) infinite;
    animation-delay: 0.3s;
  }

  @keyframes scs-radiate-up {
    0%        { top: 50%; opacity: 0; }
    12%       { opacity: 1; }
    85%, 100% { top: 6%; opacity: 0; }
  }
  @keyframes scs-radiate-down {
    0%        { top: 50%; opacity: 0; }
    12%       { opacity: 1; }
    85%, 100% { top: 94%; opacity: 0; }
  }
  @keyframes scs-blink {
    0%, 50%   { opacity: 1; }
    50.01%, 100% { opacity: 0; }
  }

  /* hover the source → every surface + the wires brighten together */
  .scs:has(.scs__source:hover) .scs__surface,
  .scs__surface:hover {
    border-color: var(--border-default);
  }
  .scs:has(.scs__source:hover) .scs__surface::before,
  .scs__surface:hover::before {
    background: var(--accent);
    opacity: 0.9;
  }

  /* ── MOBILE: stack source → flow indicator → surfaces ───────────── */
  @media (max-width: 880px) {
    .scs {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      row-gap: 0;
      margin-top: 24px;
    }
    .scs__source {
      grid-column: 1;
      grid-row: auto;
      align-self: stretch;
      overflow-x: auto;
    }
    .scs__source::before { left: 0; }
    .scs__source::after { display: none; }
    .scs__code { font-size: 12px; }

    /* rail collapses to a short vertical "flows into" connector */
    .scs__rail {
      grid-column: 1;
      grid-row: auto;
      height: 32px;
      margin: 4px auto;
    }
    .scs__spine {
      top: 0; bottom: 0;
      background: linear-gradient(to bottom, var(--border-default), transparent);
    }
    .scs__hub { top: 0; }
    .scs__pulse--up { display: none; }
    .story-card.is-active .scs__pulse--down {
      animation: scs-radiate-mobile 2s var(--ease-out) infinite;
    }
    @keyframes scs-radiate-mobile {
      0%   { top: 0; opacity: 0; }
      15%  { opacity: 1; }
      100% { top: 100%; opacity: 0; }
    }

    .scs__surfaces {
      grid-column: 1;
      grid-row: auto;
    }
    .scs__surface { transform: translateY(10px); }
    .scs__surface::before { display: none; }
    .story-card.is-active .scs__surface { transform: translateY(0); }
  }

  /* ── Reduced motion ─────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .scs__surface { opacity: 1; transform: none; transition: none; }
    .scs__pulse, .scs__caret { animation: none; }
    .scs__pulse { opacity: 0; }
  }
</style>
