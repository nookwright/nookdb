---
/**
 * AiReady — the vibe-coder hook. NookDB is built for AI-assisted development:
 * schema-first types the assistant can't get wrong, typed errors it can fix,
 * and the whole reference exposed as llms.txt / llms-full.txt for one-shot
 * context. A copyable prompt + the two doc-feed links.
 */
import { copy } from '../lib/copy';
const c = copy.aiReady;
---

<section class="ai section-reveal reveal-stagger" aria-label="Built for AI-assisted development">
  <div class="ai__inner">
    <header class="ai__head reveal-item" style="--rev-i: 0">
      <span class="ai__kicker">{c.kicker}</span>
      <h2 class="ai__heading">{c.heading}</h2>
      <p class="ai__body">{c.body}</p>
    </header>

    <div class="ai__grid">
      <!-- ── Copyable prompt card ───────────────────────────────────── -->
      <div class="ai__prompt reveal-item" style="--rev-i: 1">
        <div class="ai__prompt-chrome">
          <span class="ai__prompt-spark" aria-hidden="true">✦</span>
          <span class="ai__prompt-label">{c.promptLabel}</span>
        </div>
        <p class="ai__prompt-text">{c.prompt}</p>
        <div class="ai__prompt-bar">
          <button
            class="ai__copy"
            type="button"
            data-copy-install
            aria-label="Copy the AI prompt to clipboard"
          >
            <span class="sr-only" data-copy-text>{c.prompt}</span>
            <span data-copy-hint>{c.copyCta}</span>
          </button>
          <span class="ai__links">
            {c.links.map((l) => (
              <a class="ai__link" href={l.href}>{l.label}</a>
            ))}
          </span>
        </div>
        <p class="ai__upcoming"><span class="ai__upcoming-mark" aria-hidden="true">◇</span>{c.upcoming}</p>
      </div>

      <!-- ── Why it works with AI ───────────────────────────────────── -->
      <ul class="ai__points reveal-item" style="--rev-i: 2">
        {c.points.map((p) => (
          <li class="ai__point">
            <h3 class="ai__point-title">{p.title}</h3>
            <p class="ai__point-body" set:html={p.body.replace(/`(.+?)`/g, '<code>$1</code>')}></p>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .ai {
    padding: 96px 24px;
  }

  .ai__inner {
    max-width: 1040px;
    margin: 0 auto;
  }

  /* ── Heading ─────────────────────────────────────────────────────── */
  .ai__head {
    max-width: 620px;
    margin: 0 0 48px;
  }

  .ai__kicker {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--mint);
    margin-bottom: 14px;
  }

  .ai__heading {
    font-family: var(--font-sans);
    font-size: 28px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    margin: 0 0 14px;
  }

  .ai__body {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.55;
    color: var(--text-muted);
    margin: 0;
  }

  /* ── Grid: prompt card | points ──────────────────────────────────── */
  .ai__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 28px;
    align-items: start;
  }

  /* ── Prompt card ─────────────────────────────────────────────────── */
  .ai__prompt {
    position: relative;
    background: var(--bg-code);
    border: 1px solid var(--border-default);
    border-radius: var(--r-lg);
    padding: 0 0 16px;
    overflow: hidden;
    box-shadow: var(--shadow-elevated);
  }
  .ai__prompt::before {
    content: '';
    position: absolute;
    top: -40%;
    left: -10%;
    width: 60%;
    height: 80%;
    background: radial-gradient(circle, rgba(168, 201, 127, 0.12) 0%, transparent 62%);
    filter: blur(28px);
    pointer-events: none;
  }

  .ai__prompt-chrome {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 12px 18px;
    border-bottom: 1px solid var(--border-subtle);
    background: var(--bg-popover);
  }
  .ai__prompt-spark { color: var(--mint); font-size: 12px; line-height: 1; }
  .ai__prompt-label {
    font-family: var(--font-mono);
    font-size: 9.5px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
  }

  .ai__prompt-text {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
    padding: 18px 20px 16px;
  }

  .ai__prompt-bar {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    padding: 0 20px;
  }

  .ai__copy {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--bg);
    background: var(--mint);
    border: 1px solid var(--mint);
    border-radius: var(--r-md);
    padding: 9px 18px;
    cursor: pointer;
    transition: opacity var(--dur-fast) var(--ease-out);
  }
  .ai__copy:hover { opacity: 0.88; }
  .ai__copy:focus-visible { outline: 2px solid var(--mint); outline-offset: 2px; }
  .ai__copy [data-copy-hint][data-copied] { /* success state inherits color */ }

  .ai__links {
    display: inline-flex;
    align-items: center;
    gap: 16px;
  }
  .ai__link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    text-decoration: underline;
    text-decoration-color: var(--border-default);
    text-underline-offset: 3px;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .ai__link::before { content: '/'; opacity: 0.5; margin-right: 1px; }
  .ai__link:hover { color: var(--accent); }

  /* upcoming-work foreshadow inside the prompt card */
  .ai__upcoming {
    margin: 14px 20px 18px;
    padding: 10px 12px;
    border-top: 1px dashed var(--border-subtle);
    font-family: var(--font-mono);
    font-size: 10.5px;
    line-height: 1.5;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }
  .ai__upcoming-mark {
    color: var(--mint);
    margin-right: 7px;
  }

  /* ── Points ──────────────────────────────────────────────────────── */
  .ai__points {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .ai__point {
    padding: 16px 0;
    border-top: 1px solid var(--border-subtle);
  }
  .ai__point:first-child { border-top: 0; padding-top: 0; }

  .ai__point-title {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 5px;
  }
  .ai__point-body {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-muted);
    margin: 0;
  }
  .ai__point-body code {
    font-family: var(--font-mono);
    font-size: 0.86em;
    background: var(--accent-subtle);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--text-secondary);
  }

  /* ── Accessibility helper ────────────────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* ── Mobile ──────────────────────────────────────────────────────── */
  @media (max-width: 880px) {
    .ai { padding: 72px 20px; }
    .ai__grid { grid-template-columns: 1fr; gap: 24px; }
    .ai__heading { font-size: 24px; }
  }
</style>

<script>
  import '../scripts/copy-install.ts';
  import '../scripts/reveal.ts';
</script>
