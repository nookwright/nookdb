---
interface Props {
  size?: number;
  class?: string;
  stroke?: string;
}
const { size = 48, class: className, stroke = 'currentColor' } = Astro.props;
---

<svg
  viewBox="0 0 48 48"
  fill="none"
  stroke={stroke}
  stroke-width="4"
  stroke-linecap="round"
  stroke-linejoin="round"
  width={size}
  height={size}
  class={className}
>
  <!-- Left vertical stroke of the n — Alt 1 base -->
  <path d="M10 10 L10 38" />
  <!-- Shoulder arc and inward curve creating the nook cavity -->
  <path d="M10 17 C10 11 20 10 26 16 L26 28 C26 33 30 34 34 34" />
  <!-- Right leg descends from cavity exit -->
  <path d="M34 34 L34 38" />
  <!-- Keyhole glyph inside the cavity: small circle top + narrow slot below -->
  <circle cx="20" cy="27" r="3" stroke={stroke} stroke-width="2.5" fill="none" />
  <rect x="18.5" y="30" width="3" height="5" fill={stroke} stroke="none" rx="0.5" />
</svg>
