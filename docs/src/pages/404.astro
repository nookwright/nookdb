---
import '../styles/tokens.css';
import SiteHeader from '../components/SiteHeader.astro';
import { copy } from '../lib/copy';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 · key_not_found — {copy.brand.product}</title>
    <meta name="description" content="The requested route did not resolve to a known document." />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/icon-256.png" />
  </head>
  <body>
    <SiteHeader />

    <main class="nf" aria-labelledby="nf-title">
      <!-- giant outline glyph sitting behind everything; purely atmospheric -->
      <div class="nf__glyph" aria-hidden="true">404</div>

      <article class="nf__card">
        <header class="nf__head">
          <span class="nf__tag">REPL · nookdb</span>
          <span class="nf__crumbs">
            <span class="nf__dot"></span>
            <span class="nf__dot"></span>
            <span class="nf__dot"></span>
          </span>
        </header>

        <div class="nf__body">
          <!-- the live, typed query: cursor + mint accent on the function name -->
          <p class="nf__line nf__line--prompt" style="--rev-i: 0">
            <span class="nf__prompt">&gt;</span>
            <span class="nf__code">db.routes.<span class="nf__fn">find</span>(<span class="nf__brace">{'{'}</span> path: <span class="nf__str">"<span id="nf-path">/unknown</span>"</span> <span class="nf__brace">{'}'}</span>)</span>
            <span class="nf__cursor" aria-hidden="true"></span>
          </p>

          <!-- the typed error response -->
          <pre class="nf__line nf__line--err" style="--rev-i: 1"><span class="nf__err-kind">NookError</span>: <span class="nf__err-tag">key_not_found</span>
<span class="nf__brace">{'{'}</span>
  collection: <span class="nf__str">'routes'</span>,
  query:      <span class="nf__brace">{'{'}</span> path: <span class="nf__str">'<span class="nf-path-mirror">/unknown</span>'</span> <span class="nf__brace">{'}'}</span>,
  result:     <span class="nf__null">undefined</span>,
  hint:       <span class="nf__str">'this document does not exist in the live collection'</span>
<span class="nf__brace">{'}'}</span></pre>

          <!-- next-step hints, rendered like a follow-up shell input -->
          <h1 id="nf-title" class="nf__sr">Page not found</h1>

          <p class="nf__line nf__line--hint" style="--rev-i: 2">
            <span class="nf__prompt">$</span>
            <span class="nf__hint">try one of these instead</span>
          </p>

          <ul class="nf__routes" role="list">
            <li style="--rev-i: 3"><a href="/" class="nf__route">
              <span class="nf__route-key">home</span>
              <span class="nf__route-arrow">→</span>
              <span class="nf__route-path">/</span>
            </a></li>
            <li style="--rev-i: 4"><a href="/quick-start/" class="nf__route">
              <span class="nf__route-key">quick start</span>
              <span class="nf__route-arrow">→</span>
              <span class="nf__route-path">/quick-start/</span>
            </a></li>
            <li style="--rev-i: 5"><a href="/architecture/overview/" class="nf__route">
              <span class="nf__route-key">architecture</span>
              <span class="nf__route-arrow">→</span>
              <span class="nf__route-path">/architecture/overview/</span>
            </a></li>
            <li style="--rev-i: 6"><a href="/llms.txt" class="nf__route">
              <span class="nf__route-key">llms.txt</span>
              <span class="nf__route-arrow">→</span>
              <span class="nf__route-path">/llms.txt</span>
            </a></li>
          </ul>
        </div>

        <footer class="nf__foot">
          <span class="nf__stamp">404 · key_not_found</span>
          <a class="nf__report" href="https://github.com/nookwright/nookdb/issues/new?title=Broken+link&body=Path%3A+" rel="noopener">
            report broken link →
          </a>
        </footer>
      </article>
    </main>

    <script is:inline>
      // Inject the actual missing path (404 is statically rendered, so the
      // requested URL is unknown at build time — fill it in on the client).
      // textContent escapes for us; no manual HTML sanitisation needed.
      const path = location.pathname + location.search;
      const main = document.getElementById('nf-path');
      if (main) main.textContent = path;
      document.querySelectorAll('.nf-path-mirror').forEach((el) => {
        el.textContent = path;
      });
      // wire the report link to pre-fill the path
      const report = document.querySelector('.nf__report');
      if (report) {
        const url = new URL(report.href);
        url.searchParams.set('body', 'Path: ' + path);
        report.href = url.toString();
      }
    </script>

    <style>
      /* ─── Page shell ────────────────────────────────────────────────── */
      .nf {
        position: relative;
        min-height: calc(100vh - 64px);
        display: grid;
        place-items: center;
        padding: 64px 24px 96px;
        overflow: hidden;
        isolation: isolate;
      }

      /* atmospheric oversized glyph — barely visible, sits behind card */
      .nf__glyph {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        font-family: var(--font-mono);
        font-weight: 700;
        font-size: clamp(280px, 38vw, 520px);
        line-height: 0.9;
        letter-spacing: -0.04em;
        color: transparent;
        -webkit-text-stroke: 1px var(--border-default);
        opacity: 0.55;
        pointer-events: none;
        z-index: -1;
        user-select: none;
      }
      /* radial fade so the glyph dissolves into the page */
      .nf__glyph::after {
        content: '';
        position: absolute;
        inset: -10%;
        background: radial-gradient(
          ellipse at center,
          transparent 0%,
          transparent 30%,
          var(--bg) 75%
        );
        pointer-events: none;
      }

      /* ─── Card ──────────────────────────────────────────────────────── */
      .nf__card {
        position: relative;
        width: min(640px, 100%);
        background: var(--bg-code);
        border: 1px solid var(--border-default);
        border-radius: var(--r-lg);
        box-shadow: var(--shadow-elevated);
        overflow: hidden;
        /* gentle entrance — match site reveal aesthetic */
        animation: nf-card-in 720ms var(--ease-reveal) both;
      }

      .nf__head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 14px;
        background: var(--bg-popover);
        border-bottom: 1px solid var(--border-subtle);
      }
      .nf__tag {
        font-family: var(--font-mono);
        font-size: 10.5px;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: var(--text-muted);
        font-weight: 600;
      }
      .nf__crumbs {
        display: inline-flex;
        gap: 6px;
      }
      .nf__dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--border-default);
      }

      .nf__body {
        padding: 28px 24px 24px;
      }

      /* ─── Lines (animated reveal) ──────────────────────────────────── */
      .nf__line {
        font-family: var(--font-mono);
        font-size: 12.5px;
        line-height: 1.7;
        color: var(--text-primary);
        margin: 0;
        opacity: 0;
        transform: translateY(8px);
        animation: nf-line-in 540ms var(--ease-reveal) both;
        animation-delay: calc(var(--rev-i, 0) * 90ms + 220ms);
      }
      .nf__line--prompt {
        white-space: nowrap;
        overflow-x: auto;
        padding-bottom: 4px;
      }
      .nf__line--err {
        margin-top: 14px;
        padding: 14px 16px;
        background: rgba(232, 80, 80, 0.04);
        border-left: 2px solid var(--error);
        border-radius: 0 4px 4px 0;
        white-space: pre;
        overflow-x: auto;
      }
      .nf__line--hint {
        margin-top: 22px;
      }

      .nf__prompt {
        display: inline-block;
        width: 14px;
        color: var(--mint);
        font-weight: 700;
      }
      .nf__code { color: var(--text-primary); }
      .nf__fn { color: var(--mint); font-weight: 600; }
      .nf__brace { color: var(--text-muted); }
      .nf__str { color: var(--text-secondary); }
      .nf__null { color: var(--text-caption); font-style: italic; }
      .nf__err-kind { color: var(--error); font-weight: 700; }
      .nf__err-tag {
        color: var(--text-primary);
        background: rgba(232, 80, 80, 0.12);
        padding: 1px 6px;
        border-radius: 3px;
      }
      .nf__hint { color: var(--text-muted); }

      /* blinking mint cursor at end of the live prompt line */
      .nf__cursor {
        display: inline-block;
        width: 7px;
        height: 14px;
        margin-left: 4px;
        vertical-align: -2px;
        background: var(--mint);
        box-shadow: 0 0 8px rgba(168, 201, 127, 0.55);
        animation: nf-blink 1.05s steps(1, end) infinite;
        animation-delay: 880ms;
      }
      @keyframes nf-blink {
        0%, 49%   { opacity: 1; }
        50%, 100% { opacity: 0; }
      }

      /* ─── Routes (rescue links) ────────────────────────────────────── */
      .nf__routes {
        list-style: none;
        margin: 10px 0 0;
        padding: 0;
        display: grid;
        gap: 2px;
      }
      .nf__routes li {
        opacity: 0;
        transform: translateY(8px);
        animation: nf-line-in 540ms var(--ease-reveal) both;
        animation-delay: calc(var(--rev-i, 0) * 90ms + 220ms);
      }
      .nf__route {
        display: grid;
        grid-template-columns: 132px 18px 1fr;
        align-items: baseline;
        gap: 8px;
        padding: 8px 10px;
        margin: 0 -10px;
        border-radius: var(--r-sm);
        text-decoration: none;
        font-family: var(--font-mono);
        font-size: 12px;
        transition: background var(--dur-fast) var(--ease-out);
      }
      .nf__route:hover,
      .nf__route:focus-visible {
        background: var(--accent-subtle);
        outline: none;
      }
      .nf__route:focus-visible {
        box-shadow: inset 0 0 0 1px var(--border-default);
      }
      .nf__route-key {
        color: var(--text-primary);
        font-weight: 600;
      }
      .nf__route-arrow {
        color: var(--text-muted);
        transition: transform var(--dur-fast) var(--ease-out), color var(--dur-fast);
      }
      .nf__route:hover .nf__route-arrow,
      .nf__route:focus-visible .nf__route-arrow {
        color: var(--mint);
        transform: translateX(2px);
      }
      .nf__route-path {
        color: var(--text-secondary);
        letter-spacing: 0.01em;
      }

      /* ─── Footer ────────────────────────────────────────────────────── */
      .nf__foot {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
        border-top: 1px solid var(--border-subtle);
        background: var(--bg-popover);
        font-family: var(--font-mono);
        font-size: 10.5px;
        letter-spacing: 0.04em;
      }
      .nf__stamp { color: var(--text-muted); }
      .nf__report {
        color: var(--text-secondary);
        text-decoration: none;
        transition: color var(--dur-fast);
      }
      .nf__report:hover { color: var(--accent); }

      /* visually hidden semantic h1 — keeps SEO/SR happy without
         competing with the REPL-as-headline composition */
      .nf__sr {
        position: absolute;
        width: 1px; height: 1px;
        margin: -1px; padding: 0;
        overflow: hidden; clip: rect(0 0 0 0);
        white-space: nowrap; border: 0;
      }

      /* ─── Animations ───────────────────────────────────────────────── */
      @keyframes nf-card-in {
        from { opacity: 0; transform: translateY(12px) scale(0.985); }
        to   { opacity: 1; transform: translateY(0)    scale(1); }
      }
      @keyframes nf-line-in {
        to { opacity: 1; transform: translateY(0); }
      }

      /* ─── Responsive ───────────────────────────────────────────────── */
      @media (max-width: 520px) {
        .nf__body { padding: 22px 18px 18px; }
        .nf__route {
          grid-template-columns: 1fr;
          gap: 2px;
        }
        .nf__route-arrow { display: none; }
        .nf__line, .nf__route { font-size: 11.5px; }
      }

      @media (prefers-reduced-motion: reduce) {
        .nf__card, .nf__line, .nf__routes li { animation: none; opacity: 1; transform: none; }
        .nf__cursor { animation: none; opacity: 1; }
      }
    </style>
  </body>
</html>
