{
  "name": "@nookdb/binding",
  "version": "1.1.0",
  "description": "NAPI-rs binding for nookdb-core. Platform-dispatch loader; binary lives in @nookdb/binding-<triple> sibling packages.",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nookwright/nookdb.git",
    "directory": "crates/nookdb-napi"
  },
  "homepage": "https://github.com/nookwright/nookdb#readme",
  "engines": {
    "node": ">= 20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "napi": {
    "binaryName": "nookdb-binding",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release --js index.js --dts index.d.ts",
    "build:debug": "napi build --platform --js index.js --dts index.d.ts"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2"
  }
}
